{
  "name": "super-seat-map",
  "version": "1.0.2",
  "description": "超级座位图 - 班级座位管理工具",
  "author": "Lianghaoliu",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "build": "vite build",
    "start": "electron .",
    "pack": "vite build && electron-builder --dir",
    "dist": "vite build && electron-builder",
    "dist:win": "vite build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.superseatmap.app",
    "productName": "超级座位图",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icons/seat-icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}